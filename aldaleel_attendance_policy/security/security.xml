<odoo>
    <data>
        <record id="res_groups_privilege_payroll_custom" model="res.groups.privilege">
            <field name="name">Payroll Approval System</field>
            <field name="sequence">20</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
        </record>

        <record id="group_hr_payroll_user_custom" model="res.groups">
            <field name="name">HR Preparer</field>
            <field name="sequence">10</field>
            <field name="privilege_id" ref="res_groups_privilege_payroll_custom"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_general_manager" model="res.groups">
            <field name="name">General Manager</field>
            <field name="sequence">20</field>
            <field name="privilege_id" ref="res_groups_privilege_payroll_custom"/>
            <field name="implied_ids" eval="[(4, ref('group_hr_payroll_user_custom'))]"/>
        </record>

        <record id="group_accounting_user_custom" model="res.groups">
            <field name="name">Accounting Paymaster</field>
            <field name="sequence">30</field>
            <field name="privilege_id" ref="res_groups_privilege_payroll_custom"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>