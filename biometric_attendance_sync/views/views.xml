<odoo>
        <record id="view_employee_form_inherit_device" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.device</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">


                <xpath expr="//sheet//group" position="inside">
                    <field name="device_id" groups="base.group_system"/>
                    <field name="device_make" groups="base.group_system"/>

                </xpath>

            </field>
        </record>


    <record id="view_employee_public_form_inherit_device" model="ir.ui.view">
    <field name="name">hr.employee.public.form.device</field>
    <field name="model">hr.employee.public</field>
    <field name="inherit_id" ref="hr.hr_employee_public_view_form"/>
    <field name="arch" type="xml">
        <xpath expr="//sheet//group" position="inside">
            <field name="device_id"/>
            <field name="device_make"/>
        </xpath>
    </field>
</record>

