<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_attendance_report_wizard_form" model="ir.ui.view">
        <field name="name">attendance.report.wizard.form</field>
        <field name="model">attendance.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Attendance Report">
                <sheet>
                    <div class="oe_title">
                        <h1>Print Attendance Report</h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_from" widget="date" required="1"/>
                        </group>
                        <group>
                            <field name="date_to" widget="date" required="1"/>
                        </group>
                    </group>
                    <p class="text-muted">
                        Select the date range for the employees' attendance records.
                    </p>
                </sheet>
                <footer>
                    <button name="action_print_report"
                            type="object"
                            string="Print PDF"
                            class="btn-primary"
                            data-hotkey="q"/>
                    <button string="Discard"
                            class="btn-secondary"
                            special="cancel"
                            data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>


    <record id="action_attendance_report_server" model="ir.actions.server">
        <field name="name">Attendance Report</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="binding_model_id" ref="hr.model_hr_employee"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = {
            'type': 'ir.actions.act_window',
            'name': 'Attendance Report',
            'res_model': 'attendance.report.wizard',
            'view_mode': 'form',
            'target': 'new',
            'context': {
            'active_ids': records.ids,
            'active_model': 'hr.employee',
            }
            }
        </field>
    </record>

