<odoo>

    <record id="hr_leave_form_inherit_replacement" model="ir.ui.view">
        <field name="name">hr.leave.form.inherit.replacement</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_manager"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='holiday_status_id']" position="after">
                <field name="replacement_employee_id"
                       domain="[('id', '!=', employee_id)]"
                       options="{'no_create': True}"/>
                <field name="is_exception"/>
                <field name="emergency_degree"/>

            </xpath>

        </field>
    </record>

</odoo>