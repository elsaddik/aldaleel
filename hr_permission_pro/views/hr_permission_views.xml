<odoo>

    <record id="view_permission_list" model="ir.ui.view">
        <field name="name">hr.permission.list</field>
        <field name="model">hr.permission</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="date"/>
                <field name="permission_type"/>
                <field name="time_from"/>
                <field name="time_to"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_permission_form" model="ir.ui.view">
        <field name="name">hr.permission.form</field>
        <field name="model">hr.permission</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit"
                            invisible="state != 'draft'" type="object" string="Submit"/>
                    <button name="action_approve"     invisible="state == 'approved'" type="object" string="Approve"/>
                    <button name="action_refuse"      invisible="state != 'to_approve'" type="object" string="Refuse"/>
                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="date"/>
                        <field name="permission_type"/>
                        <field name="time_from"/>
                        <field name="time_to"/>
                        <field name="duration" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

      <record id="action_permission" model="ir.actions.act_window">
        <field name="name">Permissions</field>
        <field name="res_model">hr.permission</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_permission_root"
              name="Permissions"
              parent="hr.menu_hr_root"/>

    <menuitem id="menu_permission"
              name="Employee Permissions"
              parent="menu_permission_root"
              action="action_permission"/>



    <record id="view_hr_attendance_form_inherit_custom" model="ir.ui.view">
    <field name="name">hr.attendance.form.inherit.custom</field>
    <field name="model">hr.attendance</field>
    <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
    <field name="arch" type="xml">


        <xpath expr="//field[@name='check_out']" position="after">
            <field name="delay_minutes" invisible="1"/>
            <field name="early_minutes" invisible="1"/>
            <field name="delay_display"/>
            <field name="early_display"/>
        </xpath>

    </field>
</record>


</odoo>