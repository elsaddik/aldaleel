<odoo>

    <!-- Scheduled Action for Carry Forward Leaves -->
    <record id="ir_cron_carry_forward_leaves" model="ir.cron">
        <field name="name">Carry Forward Leaves</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave"/>
        <field name="state">code</field>
        <field name="code">model.carry_forward_leaves()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">12</field>
        <field name="interval_type">months</field>
    </record>


    <record id="ir_cron_check_annual_leave_balance" model="ir.cron">
        <field name="name">Check Annual Leave Balance</field>
        <!-- الموديل اللي فيه الميثود -->
        <field name="model_id" ref="hr_holidays.model_hr_leave"/>
        <field name="state">code</field>
        <field name="code">model.check_annual_leave_balance()</field>
        <!-- المستخدم اللي يشغل الكرون -->
        <field name="user_id" ref="base.user_root"/>
        <!-- يتكرر كل شهر -->
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>



        <!-- أول تشغيل -->
<!--        <field name="nextcall">2026-01-01 09:00:00</field>-->

    </record>



    <record id="ir_cron_check_sick_leave_docs" model="ir.cron">
    <field name="name">Check Sick Leave Documents</field>
    <field name="model_id" ref="hr_holidays.model_hr_leave"/>
    <field name="state">code</field>
    <field name="code">model.check_sick_leave_documents()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">days</field>

</record>

</odoo>

